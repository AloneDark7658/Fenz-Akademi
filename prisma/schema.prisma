// ============================================================================
// Fenz Akademi — Prisma Veritabanı Şeması
// Ortaokul (5-8. sınıf) Eğitim Platformu
// ============================================================================
// Güvenlik Notları:
// - passwordHash: bcrypt ile hash'lenir, düz metin ASLA saklanmaz
// - email: @unique — duplicate kayıt önlenir
// - Progress & QuizResult: composite unique ile duplicate kayıt önlenir
// - options alanı Json tipinde — esnek soru seçenekleri için
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// ─── Enum Tanımları ─────────────────────────────────────────────────────────

/// Kullanıcı rolleri — RBAC middleware'de kullanılır
enum Role {
  STUDENT
  TEACHER
  PARENT
  ADMIN
}

/// Soru durumu — DRAFT henüz yayınlanmamış, PUBLISHED öğrencilere açık
enum QuestionStatus {
  DRAFT
  PUBLISHED
}

/// Canlı ders oturumu durumu
enum LiveSessionStatus {
  SCHEDULED  /// Planlanmış, henüz başlamadı
  LIVE       /// Devam ediyor
  ENDED      /// Sona erdi
}

// ─── Kullanıcı Modeli ───────────────────────────────────────────────────────

/// Platform kullanıcısı (öğrenci, öğretmen, veli veya yönetici)
model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(STUDENT)
  classLevel   Int?     @map("class_level") /// 5, 6, 7 veya 8. sınıf
  points       Int      @default(0) /// Gamification puanı
  streak       Int      @default(0) /// Günlük ardışık çalışma serisi
  avatarUrl    String?  @map("avatar_url")
  parentId     String?  @map("parent_id") /// Velinin ID'si (Eğer öğrenciyse)
  inviteCode   String?  @unique @map("invite_code") /// Öğrenci ile veliyi eşleştiren 6 haneli kod
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // İlişkiler
  parent          User?                @relation("ParentStudent", fields: [parentId], references: [id])
  children        User[]               @relation("ParentStudent")
  progresses      Progress[]
  quizResults     QuizResult[]
  userBadges      UserBadge[]
  // Canlı ders ilişkileri
  taughtSessions  LiveSession[]        @relation("TeacherSessions")
  pollVotes       LivePollVote[]       @relation("StudentPollVotes")
  consents        StudentConsent[]     @relation("StudentConsents")
  sessionMembers  LiveSessionMember[]  @relation("StudentSessions")

  @@index([role])
  @@index([classLevel])
  @@index([parentId])
  @@map("users")
}

// ─── Kurs Modeli ────────────────────────────────────────────────────────────

/// Bir dersin ana kurs birimi (ör: "6. Sınıf Matematik")
model Course {
  id          String   @id @default(uuid())
  title       String
  description String?
  gradeLevel  Int      @map("grade_level") /// Hedef sınıf seviyesi (5-8)
  imageUrl    String?  @map("image_url")
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // İlişkiler
  videoLessons  VideoLesson[]
  liveSessions  LiveSession[]

  @@index([gradeLevel])
  @@map("courses")
}

// ─── Video Ders Modeli ──────────────────────────────────────────────────────

/// Bir kurs içindeki tekil video ders
model VideoLesson {
  id                  String   @id @default(uuid())
  courseId             String   @map("course_id")
  title               String
  bunnyVideoId        String?  @map("bunny_video_id")
  duration            Int?     /// Saniye cinsinden video süresi
  orderIndex          Int      @default(0) @map("order_index")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // İlişkiler
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions   Question[]
  progresses  Progress[]
  quizResults QuizResult[]

  @@index([courseId])
  @@index([courseId, orderIndex])
  @@map("video_lessons")
}

// ─── Soru Modeli ────────────────────────────────────────────────────────────

/// Bir video derse bağlı çoktan seçmeli soru
model Question {
  id            String         @id @default(uuid())
  lessonId      String         @map("lesson_id")
  content       String         /// Soru metni (XSS sanitizasyonundan geçirilir)
  imageUrl      String?        @map("image_url")
  options       Json           /// Seçenekler dizisi: ["A seçeneği", "B seçeneği", ...]
  correctAnswer String         @map("correct_answer")
  isAiGenerated Boolean        @default(false) @map("is_ai_generated")
  status        QuestionStatus @default(DRAFT)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  // İlişkiler
  lesson VideoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([lessonId, status])
  @@map("questions")
}

// ─── İlerleme Modeli ────────────────────────────────────────────────────────

/// Öğrencinin bir video dersteki izleme ilerlemesi
model Progress {
  id              String   @id @default(uuid())
  studentId       String   @map("student_id")
  lessonId        String   @map("lesson_id")
  watchPercentage Float    @default(0) @map("watch_percentage") /// 0.0 - 100.0
  isCompleted     Boolean  @default(false) @map("is_completed")
  lastWatchedAt   DateTime @default(now()) @map("last_watched_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // İlişkiler
  student User        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson  VideoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
  @@index([studentId])
  @@map("progress")
}

// ─── Quiz Sonucu Modeli ─────────────────────────────────────────────────────

/// Öğrencinin bir quiz'deki sonucu
model QuizResult {
  id           String   @id @default(uuid())
  studentId    String   @map("student_id")
  lessonId     String   @map("lesson_id")
  correctCount Int      @default(0) @map("correct_count")
  wrongCount   Int      @default(0) @map("wrong_count")
  score        Float    @default(0) /// 0.0 - 100.0 arası yüzdelik puan
  completedAt  DateTime @default(now()) @map("completed_at")
  createdAt    DateTime @default(now()) @map("created_at")

  // İlişkiler
  student User        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson  VideoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
  @@index([studentId])
  @@index([studentId, score])
  @@map("quiz_results")
}

// ─── Oyunlaştırma Modelleri ─────────────────────────────────────────────────

/// Sistemdeki tüm kazanılabilir rozetler
model Badge {
  id              String   @id @default(uuid())
  name            String
  description     String
  icon            String   /// İkon veya emoji
  requirementType String   @map("requirement_type") /// STREAK, QUIZ_SCORE, TOTAL_XP vs.
  requirementValue Int     @map("requirement_value")
  createdAt       DateTime @default(now()) @map("created_at")

  // İlişkiler
  userBadges      UserBadge[]

  @@map("badges")
}

/// Öğrencilerin kazandığı rozetler
model UserBadge {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  badgeId   String   @map("badge_id")
  awardedAt DateTime @default(now()) @map("awarded_at")

  // İlişkiler
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId]) // Bir kullanıcı aynı rozeti bir kez kazanabilir
  @@index([userId])
  @@map("user_badges")
}

// ─── Canlı Ders Modelleri ───────────────────────────────────────────────────

/// Öğretmenin oluşturduğu canlı ders oturumu
model LiveSession {
  id              String            @id @default(uuid())
  title           String
  scheduledFor    DateTime          @map("scheduled_for")
  roomName        String            @unique @map("room_name") /// Daily.co oda adı (benzersiz)
  status          LiveSessionStatus @default(SCHEDULED)
  teacherId       String            @map("teacher_id")
  courseId        String?           @map("course_id")
  /// Sınıf seviyesi (5-8) — sınıf bazlı gruplama için
  gradeLevel      Int?              @map("grade_level")
  /// Grup numarası (1, 2, 3...) — aynı sınıfın alt grupları için
  groupIndex      Int?              @map("group_index")
  /// Ana oturum ID'si — alt grupları birbirine bağlar
  parentSessionId String?           @map("parent_session_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  // İlişkiler
  teacher       User                @relation("TeacherSessions", fields: [teacherId], references: [id])
  course        Course?             @relation(fields: [courseId], references: [id])
  polls         LivePoll[]
  consents      StudentConsent[]
  members       LiveSessionMember[]
  childSessions LiveSession[]       @relation("SessionGroups")
  parentSession LiveSession?        @relation("SessionGroups", fields: [parentSessionId], references: [id])

  @@index([teacherId])
  @@index([status])
  @@index([gradeLevel])
  @@index([parentSessionId])
  @@map("live_sessions")
}

/// Öğretmenin canlı ders sırasında oluşturduğu anket sorusu
model LivePoll {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  question    String   /// Soru metni
  options     Json     /// Şıklar dizisi: ["A şıkkı", "B şıkkı", ...] (maks 4)
  isActive    Boolean  @default(true) @map("is_active")    /// Öğrenciler oy verebilir mi
  isCompleted Boolean  @default(false) @map("is_completed") /// Sonuçlar gösterilsin mi
  createdAt   DateTime @default(now()) @map("created_at")

  // İlişkiler
  session LiveSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  votes   LivePollVote[]

  @@index([sessionId])
  @@index([sessionId, isActive])
  @@map("live_polls")
}

/// Öğrencinin anket sorusuna verdiği oy
model LivePollVote {
  id             String   @id @default(uuid())
  pollId         String   @map("poll_id")
  studentId      String   @map("student_id")
  selectedOption Int      @map("selected_option") /// Şık indeksi: 0, 1, 2 veya 3
  createdAt      DateTime @default(now()) @map("created_at")

  // İlişkiler
  poll    LivePoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  student User     @relation("StudentPollVotes", fields: [studentId], references: [id])

  @@unique([pollId, studentId]) /// Bir öğrenci bir ankete sadece 1 oy verebilir
  @@index([pollId])
  @@map("live_poll_votes")
}

/// Bir canlı ders grubuna atanan öğrenci kaydı
model LiveSessionMember {
  id        String      @id @default(uuid())
  sessionId String      @map("session_id")
  studentId String      @map("student_id")
  createdAt DateTime    @default(now()) @map("created_at")

  session   LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   User        @relation("StudentSessions", fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
  @@map("live_session_members")
}

/// KVKK kapsamında öğrenci onay kaydı — hukuki loglama
model StudentConsent {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  sessionId   String   @map("session_id")
  consentType String   @map("consent_type") /// Örn: "KVKK_LIVE_CLASS"
  ipAddress   String?  @map("ip_address")   /// Hukuki kanıt için IP adresi
  userAgent   String?  @map("user_agent")   /// Tarayıcı/cihaz bilgisi
  createdAt   DateTime @default(now()) @map("created_at")

  // İlişkiler
  student User        @relation("StudentConsents", fields: [studentId], references: [id])
  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([sessionId])
  @@map("student_consents")
}
